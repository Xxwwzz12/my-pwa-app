{
  "name": "AI Помощник",
  "short_name": "AI Assistant",
  "description": "Ваш персональный помощник с искусственным интеллектом",
  "start_url": "/",
  "display": "standalone",
  "theme_color": "#4263eb",
  "background_color": "#f0f2f5",
  "icons": [
    {
      "src": "/icon-192.png",
      "type": "image/png",
      "sizes": "192x192",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512-maskable.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshot1.png",
      "type": "image/png",
      "sizes": "1080x1920"
    },
    {
      "src": "/screenshot2.png",
      "type": "image/png",
      "sizes": "1920x1080"
    }
  ],
  "features": [
    "Чат с ИИ",
    "Управление задачами",
    "Календарь событий",
    "Оффлайн доступ"
  ],
  "categories": [
    "productivity",
    "utilities"
  ],
  "shortcuts": [
    {
      "name": "Новый чат",
      "short_name": "Чат",
      "description": "Начать новый разговор с ИИ",
      "url": "/chat.html",
      "icons": [
        {
          "src": "/icon-chat.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Мой календарь",
      "short_name": "Календарь",
      "description": "Просмотр предстоящих событий",
      "url": "/calendar.html",
      "icons": [
        {
          "src": "/icon-calendar.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+aiassistant",
      "url": "/?action=%s"
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "file_handlers": [
    {
      "action": "/file-handler",
      "accept": {
        "text/plain": [".txt"],
        "application/pdf": [".pdf"]
      }
    }
  ]
}